{
  "name": "pyxis",
  "version": "0.29.0",
  "private": true,
  "scripts": {
    "preinstall": "node ./scripts/check-pnpm.js",
    "dev": "pnpm run setup-build && vite",
    "build": "pnpm run setup-build && vite build",
    "start": "pnpm run preview",
    "setup-build": "rm -rf public/locales && cp -r locales public/locales && node scripts/build/initial_files_to_ts.js && node scripts/build/build-extensions.js && cp extensions/registry.json public/extensions/registry.json && cp node_modules/esbuild-wasm/esbuild.wasm public/esbuild.wasm",
    "format": "bash scripts/i18n/format_locales.sh && pnpm exec biome format --write src/",
    "lint": "pnpm exec biome check src/",
    "lint:report": "pnpm biome lint src --max-diagnostics=none --reporter=default --reporter-file=lint-report/report.txt",
    "lint:fix": "pnpm exec biome check --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "tree": "pnpm run build && ./tree.sh && ./tree-built-out.sh",
    "preview": "vite preview",
    "create-extension": "node scripts/extensions/create-extension.js",
    "clean": "rm -rf node_modules package-lock.json",
    "reinstall": "pnpm run clean && pnpm install"
  },
  "packageManager": "pnpm@11.3.0",
  "dependencies": {
